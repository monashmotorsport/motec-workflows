[flake8]
# Recommend matching the black line length (default 88),
# rather than using the flake8 default of 79:
max-line-length = 88
extend-ignore =
    # See https://github.com/PyCQA/pycodestyle/issues/373
    E203,
    # Do not complain about lambda assignments
    E731,
    # Do not complain about imports not being at the top of the file
    E402
max-complexity = 10
